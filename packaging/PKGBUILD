# Maintainer: murshid1988 <murshid1988@gmail.com>
pkgname=branchify
pkgver=1.1.3
pkgrel=1
pkgdesc="Convert an arbitrary string into a valid git branch name"
arch=('any')
url="https://github.com/murshid1988/branchify"
license=('MIT')
source=("https://github.com/murshid1988/branchify/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('39344220ba5fd9cbbba6a113816fe29b87d22cabe5497f88c4f1975c02190303')

package() {
  cd "$srcdir/branchify-${pkgver}"
  install -Dm755 branchify.sh "$pkgdir/usr/bin/branchify"
  install -Dm644 branchify.1 "$pkgdir/usr/share/man/man1/branchify.1"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
